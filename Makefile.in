# Build driver for autossh.
#
# The binary is produced by `cargo build --release`. cargo invokes
# build.rs which compiles the small C shim (c-shim/errlog.c) via the
# cc crate and links it into the final binary. This Makefile is a
# thin convenience wrapper so users with the autoconf habit see
# familiar targets.

VER=		1.4g
SSH=		@path_ssh@

prefix=		@prefix@
exec_prefix=	@exec_prefix@
bindir=		@bindir@
datadir=	@datadir@
datarootdir=	@datarootdir@
mandir=		@mandir@

SRCDIR=		@srcdir@
VPATH=		@srcdir@

TARGET=		autossh
CARGO_BIN=	target/release/$(TARGET)

all:		$(TARGET)


$(TARGET):	$(CARGO_BIN)
		cp $(CARGO_BIN) $(TARGET)

$(CARGO_BIN):	FORCE
		cargo build --release

.PHONY: FORCE
FORCE:

check:		$(TARGET)
		$(MAKE) -C tests check

clean:
		- /bin/rm -f *.o *.a *.core *~ $(TARGET)
		- $(MAKE) -C tests clean 2>/dev/null || true
		- cargo clean 2>/dev/null || true

allclean:	clean

distclean:	allclean
		- /bin/rm -f config.log config.cache config.status config.h
		- /bin/rm -rf autom4te.cache
		- /bin/rm -f Makefile

install:	$(TARGET)
		mkdir -p -m 755 $(DESTDIR)$(bindir)
		mkdir -p -m 755 $(DESTDIR)$(prefix)/share/doc/autossh
		mkdir -p -m 755 $(DESTDIR)$(datadir)/examples/autossh
		mkdir -p -m 755 $(DESTDIR)$(mandir)/man1
		cp $(TARGET) $(DESTDIR)$(bindir)
		cp CHANGES README $(DESTDIR)$(datadir)/doc/autossh
		cp autossh.host	$(DESTDIR)$(datadir)/examples/autossh
		cp rscreen $(DESTDIR)$(datadir)/examples/autossh
		cp autossh.1 $(DESTDIR)$(mandir)/man1
		chmod 755 $(DESTDIR)$(bindir)/$(TARGET)
		chmod 644 $(DESTDIR)$(datadir)/doc/autossh/CHANGES
		chmod 644 $(DESTDIR)$(datadir)/doc/autossh/README
		chmod 644 $(DESTDIR)$(datadir)/examples/autossh/autossh.host
		chmod 644 $(DESTDIR)$(datadir)/examples/autossh/rscreen
		chmod 644 $(DESTDIR)$(mandir)/man1/autossh.1
